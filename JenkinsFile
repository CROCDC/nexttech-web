pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = 'pantech-web'
        DOCKER_TAG = 'latest'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Deploy') {
            steps {
                sh 'docker compose down || true'
                sh 'docker compose up -d --build'
            }
        }
    }
    
    post {
        success {
            echo 'Pipeline ejecutada exitosamente'
        }
        failure {
            echo 'Pipeline falló'
        }
        always {
            cleanWs()
        }
    }
}
