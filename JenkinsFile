pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'pantech-web'
        DOCKER_TAG = 'latest'
    }

    stages {
        stage('Deploy') {
            steps {
                sh '''
                    docker compose down
                    docker compose up -d --build
                '''
            }
        }
    }

    post {
        failure {
            sh 'docker logs pantech-web'
            echo 'Pipeline falló'
        }
        always {
            cleanWs()
        }
    }
}