pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = 'pantech-web'
        DOCKER_TAG = 'latest'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'ls -la'
            }
        }
        
        stage('Deploy') {
            steps {
                sh 'docker compose down || true'
                sh 'docker compose up -d --build'
                sh 'sleep 5' // Esperar a que el contenedor esté listo
                sh 'docker ps'
                sh 'docker exec pantech-web ls -la /var/www/html'
                sh 'docker exec pantech-web nginx -t'
            }
        }
    }
    
    post {
        success {
            echo 'Pipeline ejecutada exitosamente'
        }
        failure {
            echo 'Pipeline falló'
            sh 'docker logs pantech-web'
        }
        always {
            cleanWs()
        }
    }
}
