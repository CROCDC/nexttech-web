pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'pantech-web'
        DOCKER_TAG = 'latest'
    }

    stages {
        stage('Deploy') {
            steps {
                sh '''
                    docker compose down || true
                    docker compose up -d --build
                    sleep 10
                    docker compose exec db pg_isready -U pantech || exit 1
                    docker compose exec web flask db upgrade || exit 1
                '''
            }
        }
    }

    post {
        failure {
            sh '''
                docker compose logs web
                docker compose logs db
            '''
        }
        always {
            cleanWs()
        }
    }
}