pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'pantech-web'
        DOCKER_TAG = 'latest'
    }

    stages {
        stage('Deploy') {
            steps {
                sh '''
                    docker compose down || true
                    docker compose up -d --build
                    
                    # Esperar a que la base de datos esté lista
                    for i in {1..30}; do
                        if docker compose exec db pg_isready -U pantech; then
                            break
                        fi
                        sleep 1
                    done
                    
                    # Ejecutar migraciones
                    docker compose exec web flask db upgrade
                    
                    # Verificar que la tabla existe
                    docker compose exec db psql -U pantech -d pantech -c "\\dt job_applications" || exit 1
                '''
            }
        }
    }

    post {
        failure {
            sh '''
                docker compose logs web
                docker compose logs db
            '''
        }
        always {
            cleanWs()
        }
    }
}